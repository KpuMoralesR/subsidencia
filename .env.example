# ============================================
# CONFIGURACIÓN DE ENTORNO - BASEDR (EJEMPLO)
# Django + React + PostgreSQL
# ============================================
# Este archivo sirve como plantilla para crear tu .env
# Copia este archivo como .env y completa con tus valores reales

# ============================================
# DJANGO BACKEND CONFIGURATION
# ============================================

# Secret Key (CAMBIAR - Generar con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=tu-secret-key-aqui

# Debug Mode (NUNCA usar True en producción)
DEBUG=True

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================

# Nombre de la base de datos
DB_NAME=base

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL
DB_PASSWORD=tu-password-aqui

# Host de la base de datos
DB_HOST=localhost

# Puerto de PostgreSQL
DB_PORT=5432

# ============================================
# JWT CONFIGURATION
# ============================================

# Tiempo de vida del Access Token (en minutos)
JWT_ACCESS_TOKEN_LIFETIME=60

# Tiempo de vida del Refresh Token (en días)
JWT_REFRESH_TOKEN_LIFETIME=1

# ============================================
# CORS CONFIGURATION
# ============================================

# Orígenes permitidos para CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Permitir todos los orígenes (solo desarrollo)
CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# URL del backend API
VITE_API_URL=http://localhost:8000

# URL base del frontend
VITE_FRONTEND_URL=http://localhost:5173

# ============================================
# SECURITY SETTINGS (PRODUCCIÓN)
# ============================================

# HTTPS (activar en producción)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HSTS (activar en producción)
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ============================================
# EMAIL CONFIGURATION (Opcional)
# ============================================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@ejemplo.com
# EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicacion

# ============================================
# LOGGING (Opcional)
# ============================================

# LOG_LEVEL=INFO
# LOG_FILE=logs/basedr.log

# ============================================
# SUPERUSER INICIAL (Para creación automática)
# ============================================

# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@basedr.local
# DJANGO_SUPERUSER_PASSWORD=admin123
